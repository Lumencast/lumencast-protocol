{
  "lsml": "1.0",
  "scene_id": "broadcast-scoreboard",
  "scene_version": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
  "metadata": {
    "author": "Lumencast",
    "description": "Broadcast overlay reference bundle. Twitch-style esports scoreboard with team logos, live scores, animated score-flash transitions, and a player roster with per-player stats. Designed to render under 1080p inside a CEF browser source compositied over a game capture.",
    "tags": ["broadcast", "esports", "reference"]
  },
  "layout": {
    "kind": "frame",
    "size": { "w": 1920, "h": 1080 },
    "background": "#00000000",
    "children": [
      {
        "kind": "frame",
        "size": { "w": 1920, "h": 96 },
        "position": { "x": 0, "y": 0 },
        "background": "#0f172aee",
        "children": [
          {
            "kind": "stack",
            "direction": "horizontal",
            "gap": 32,
            "padding": [16, 32, 16, 32],
            "align": "center",
            "justify": "space-between",
            "children": [
              {
                "kind": "stack",
                "direction": "horizontal",
                "gap": 16,
                "align": "center",
                "children": [
                  {
                    "kind": "image",
                    "bind": { "src": "match.team_a.logo_url" },
                    "alt": "Team A logo",
                    "size": { "w": 64, "h": 64 },
                    "fit": "contain"
                  },
                  {
                    "kind": "text",
                    "bind": { "value": "match.team_a.name" },
                    "style": { "fontSize": 32, "fontWeight": 700, "color": "#ffffff" }
                  },
                  {
                    "kind": "text",
                    "bind": { "value": "match.team_a.score" },
                    "format": { "kind": "number" },
                    "style": { "fontSize": 56, "fontWeight": 900, "color": "#fbbf24" },
                    "animate": {
                      "transition": { "duration": 250, "easing": "spring", "stiffness": 220, "damping": 18 },
                      "transform": { "scale": 1, "translate": [0, 0] }
                    }
                  }
                ]
              },
              {
                "kind": "stack",
                "direction": "vertical",
                "gap": 4,
                "align": "center",
                "children": [
                  {
                    "kind": "text",
                    "bind": { "value": "match.round_label" },
                    "style": { "fontSize": 18, "color": "#94a3b8", "textTransform": "uppercase", "letterSpacing": 2 }
                  },
                  {
                    "kind": "text",
                    "bind": { "value": "match.timer" },
                    "format": { "kind": "string" },
                    "style": { "fontSize": 28, "fontWeight": 700, "color": "#ffffff" }
                  }
                ]
              },
              {
                "kind": "stack",
                "direction": "horizontal",
                "gap": 16,
                "align": "center",
                "children": [
                  {
                    "kind": "text",
                    "bind": { "value": "match.team_b.score" },
                    "format": { "kind": "number" },
                    "style": { "fontSize": 56, "fontWeight": 900, "color": "#fbbf24" },
                    "animate": {
                      "transition": { "duration": 250, "easing": "spring", "stiffness": 220, "damping": 18 },
                      "transform": { "scale": 1, "translate": [0, 0] }
                    }
                  },
                  {
                    "kind": "text",
                    "bind": { "value": "match.team_b.name" },
                    "style": { "fontSize": 32, "fontWeight": 700, "color": "#ffffff" }
                  },
                  {
                    "kind": "image",
                    "bind": { "src": "match.team_b.logo_url" },
                    "alt": "Team B logo",
                    "size": { "w": 64, "h": 64 },
                    "fit": "contain"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "kind": "frame",
        "size": { "w": 480, "h": 720 },
        "position": { "x": 1420, "y": 120 },
        "background": "#0f172acc",
        "children": [
          {
            "kind": "stack",
            "direction": "vertical",
            "gap": 8,
            "padding": [16, 16, 16, 16],
            "children": [
              {
                "kind": "text",
                "bind": { "value": "i18n.roster_heading" },
                "style": { "fontSize": 22, "fontWeight": 700, "color": "#ffffff", "textTransform": "uppercase", "letterSpacing": 1 },
                "role": "heading"
              },
              {
                "kind": "repeat",
                "bind": { "items": "match.players" },
                "scope": "p",
                "key": "{p}.id",
                "limit": 10,
                "template": {
                  "kind": "stack",
                  "direction": "horizontal",
                  "gap": 12,
                  "align": "center",
                  "children": [
                    {
                      "kind": "image",
                      "bind": { "src": "{p}.avatar_url" },
                      "alt": "Player avatar",
                      "size": { "w": 40, "h": 40 },
                      "fit": "cover"
                    },
                    {
                      "kind": "text",
                      "bind": { "value": "{p}.handle" },
                      "style": { "fontSize": 18, "fontWeight": 700, "color": "#ffffff" }
                    },
                    {
                      "kind": "text",
                      "bind": { "value": "{p}.kda" },
                      "format": { "kind": "string" },
                      "style": { "fontSize": 16, "color": "#cbd5e1" }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "operator_inputs": [
    {
      "path": "__inputs.match.round_label",
      "label": "Round label",
      "type": "string",
      "constraints": { "maxLength": 32 },
      "writable_by": ["operator"],
      "group": "match",
      "default": "Round 1"
    },
    {
      "path": "__inputs.match.timer_visible",
      "label": "Show timer",
      "type": "boolean",
      "writable_by": ["operator"],
      "group": "match",
      "default": true
    }
  ],
  "external_adapters": [
    {
      "kind": "websocket_subscribe",
      "url": "wss://stats.example.com/match/feed",
      "writes_to": "match"
    }
  ],
  "defaults": {
    "match.team_a.name": "Team A",
    "match.team_a.score": 0,
    "match.team_a.logo_url": "https://cdn.example.com/teams/a.png",
    "match.team_b.name": "Team B",
    "match.team_b.score": 0,
    "match.team_b.logo_url": "https://cdn.example.com/teams/b.png",
    "match.round_label": "Round 1",
    "match.timer": "0:00",
    "match.players": []
  },
  "assets": {
    "allowedHosts": ["cdn.example.com", "stats.example.com"],
    "fonts": [
      {
        "family": "Inter",
        "url": "https://cdn.example.com/fonts/inter-700.woff2",
        "weight": 700,
        "style": "normal"
      }
    ]
  },
  "i18n": {
    "default_locale": "en-US",
    "locales": {
      "en-US": { "i18n.roster_heading": "Players" },
      "fr-FR": { "i18n.roster_heading": "Joueurs" }
    }
  }
}
