{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumencast.dev/schema/lsdp/1/schema-frames.json",
  "title": "LSDP/1 — frame envelope and per-type schemas",
  "description": "Mechanical companion to spec/LSDP-1.md. Validates every wire frame, server-to-client and client-to-server. Each frame is one JSON text WebSocket message.",

  "$defs": {
    "LeafPath": {
      "type": "string",
      "description": "LSDP/1 §16 LeafPath grammar — RegularPath / ScopedPath / ReservedPath.",
      "pattern": "^(?:[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z0-9_]+)*|\\{[A-Za-z_][A-Za-z0-9_]*\\}(?:\\.[A-Za-z0-9_]+)*|__[a-z]+(?:\\.[A-Za-z0-9_*-]+)+)$",
      "minLength": 1,
      "maxLength": 512
    },
    "SceneId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "SceneVersion": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "Sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "LSDP/1 §5 monotonic sequence number. Server frames carry it ; pong does not."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC (RFC 3339 profile). Optional on every server frame."
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "AUTH_DENIED",
        "WRITE_FORBIDDEN",
        "SCENE_NOT_FOUND",
        "BUNDLE_FETCH_FAILED",
        "BUNDLE_INCOMPATIBLE",
        "VERSION_GAP",
        "VERSION_MISMATCH",
        "UNKNOWN_PATH",
        "INVALID_VALUE",
        "RATE_LIMIT",
        "TEST_SESSION_EXPIRED",
        "INTERNAL"
      ],
      "description": "Closed taxonomy from spec/ERROR-CODES.md. Adding a code requires a minor version bump."
    },
    "PathScopedErrorCode": {
      "type": "string",
      "enum": ["WRITE_FORBIDDEN", "UNKNOWN_PATH", "INVALID_VALUE"],
      "description": "Subset of ErrorCode for which `path` is REQUIRED."
    },
    "LeafValue": {
      "description": "LSDP/1 §3.2.1 allowed value type. Objects are forbidden ; arrays may nest LeafValue recursively.",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/LeafValue" }
        }
      ]
    },
    "Patch": {
      "type": "object",
      "required": ["path", "value"],
      "properties": {
        "path": { "$ref": "#/$defs/LeafPath" },
        "value": { "$ref": "#/$defs/LeafValue" },
        "transition": {
          "$ref": "#/$defs/TransitionSpec",
          "description": "Optional per-leaf interpolation directive (LSDP/1.1+ §3.2.2). 1.0 receivers ignore."
        }
      },
      "additionalProperties": false
    },

    "TransitionSpec": {
      "type": "object",
      "description": "Animation directive carried on a delta patch (per-leaf, §3.2.2) or scene_changed (show-level, §3.3.1). 1.1+ field.",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["tween", "spring", "snap", "crossfade"],
          "description": "tween/spring for value interpolation ; snap = no interpolation ; crossfade = show-level only (§3.3.1)."
        },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "easing": {
          "type": "string",
          "enum": ["linear", "ease-in", "ease-out", "ease-in-out", "spring"]
        },
        "stiffness": { "type": "number", "minimum": 0 },
        "damping": { "type": "number", "minimum": 0 },
        "mass": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },

    "Cause": {
      "type": "object",
      "description": "Provenance attached to a delta (LSDP/1.1+ §3.2.3). Debug + audit only ; never load-bearing.",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "Free-form origin identifier. Conventional prefixes: operator:<user>, service:<name>, adapter:<kind>, system:<reason>."
        },
        "input_id": {
          "type": "string",
          "description": "Echoes client_msg_id from the originating input frame (§4.2)."
        }
      },
      "additionalProperties": false
    },
    "BaseEnvelope": {
      "type": "object",
      "required": ["v", "type"],
      "properties": {
        "v": {
          "type": "integer",
          "const": 1,
          "description": "Major version. MUST be 1 for LSDP/1."
        },
        "type": { "type": "string" },
        "seq": { "$ref": "#/$defs/Sequence" },
        "ts": { "$ref": "#/$defs/Timestamp" }
      }
    },

    "SnapshotFrame": {
      "type": "object",
      "required": ["v", "type", "seq", "scene_id", "scene_version", "state"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "snapshot" },
        "seq": { "$ref": "#/$defs/Sequence" },
        "ts": { "$ref": "#/$defs/Timestamp" },
        "scene_id": { "$ref": "#/$defs/SceneId" },
        "scene_version": { "$ref": "#/$defs/SceneVersion" },
        "state": {
          "type": "object",
          "description": "Flat dictionary of LeafPath → LeafValue. Keys are LeafPaths.",
          "patternProperties": {
            "^(?:[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z0-9_]+)*|__[a-z]+(?:\\.[A-Za-z0-9_*-]+)+)$": {
              "$ref": "#/$defs/LeafValue"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },

    "DeltaFrame": {
      "type": "object",
      "required": ["v", "type", "seq", "patches"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "delta" },
        "seq": { "$ref": "#/$defs/Sequence" },
        "ts": { "$ref": "#/$defs/Timestamp" },
        "patches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Patch" }
        },
        "cause": {
          "$ref": "#/$defs/Cause",
          "description": "1.1+ — delta provenance (§3.2.3)."
        }
      },
      "additionalProperties": true
    },

    "SceneChangedFrame": {
      "type": "object",
      "required": ["v", "type", "seq", "scene_id", "scene_version"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "scene_changed" },
        "seq": { "$ref": "#/$defs/Sequence" },
        "ts": { "$ref": "#/$defs/Timestamp" },
        "scene_id": { "$ref": "#/$defs/SceneId" },
        "scene_version": { "$ref": "#/$defs/SceneVersion" },
        "from_scene_id": {
          "$ref": "#/$defs/SceneId",
          "description": "1.1+ — the previously active scene id (§3.3)."
        },
        "transition": {
          "$ref": "#/$defs/TransitionSpec",
          "description": "1.1+ — show-level transition spec (§3.3.1)."
        }
      },
      "additionalProperties": true
    },

    "ErrorFrame": {
      "type": "object",
      "required": ["v", "type", "seq", "code", "message", "recoverable"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "error" },
        "seq": { "$ref": "#/$defs/Sequence" },
        "ts": { "$ref": "#/$defs/Timestamp" },
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string", "minLength": 1 },
        "recoverable": { "type": "boolean" },
        "path": { "$ref": "#/$defs/LeafPath" },
        "retry_after_ms": { "type": "integer", "minimum": 0 },
        "requested_version": { "type": "string" },
        "supported_version": { "type": "string" },
        "session": { "type": "string" }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "description": "When code is path-scoped, path is REQUIRED.",
          "if": {
            "properties": { "code": { "$ref": "#/$defs/PathScopedErrorCode" } }
          },
          "then": {
            "required": ["path"]
          }
        }
      ]
    },

    "PongFrame": {
      "type": "object",
      "required": ["v", "type"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "pong" },
        "nonce": {
          "type": "string",
          "description": "1.1+ — echoes the matching ping frame's nonce (§3.5)."
        }
      },
      "additionalProperties": true
    },

    "SubscribeFrame": {
      "type": "object",
      "required": ["v", "type", "token"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "subscribe" },
        "token": { "type": "string", "minLength": 1 },
        "scene": { "$ref": "#/$defs/SceneId" },
        "session": { "type": "string", "minLength": 1 },
        "since_sequence": {
          "$ref": "#/$defs/Sequence",
          "description": "1.1+ — request incremental resume from this seq (§4.1, §18). 1.0 servers ignore."
        }
      },
      "additionalProperties": true
    },

    "InputFrame": {
      "type": "object",
      "required": ["v", "type", "patches"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "input" },
        "patches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Patch" }
        },
        "client_msg_id": {
          "type": "string",
          "description": "1.1+ — optimistic-UI correlation. Echoed back in the resulting delta's cause.input_id (§4.2)."
        }
      },
      "additionalProperties": true
    },

    "UnsubscribeFrame": {
      "type": "object",
      "description": "1.1+ — clean teardown signal (§4.4). Server closes the WebSocket within 1 second.",
      "required": ["v", "type"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "unsubscribe" }
      },
      "additionalProperties": true
    },

    "PingFrame": {
      "type": "object",
      "required": ["v", "type"],
      "properties": {
        "v": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "ping" },
        "nonce": {
          "type": "string",
          "description": "1.1+ — correlation identifier echoed in the matching pong (§4.3, §3.5)."
        }
      },
      "additionalProperties": true
    },

    "ServerFrame": {
      "description": "Any server-to-client LSDP/1 frame. Validators MUST select on `type` after checking `v`.",
      "oneOf": [
        { "$ref": "#/$defs/SnapshotFrame" },
        { "$ref": "#/$defs/DeltaFrame" },
        { "$ref": "#/$defs/SceneChangedFrame" },
        { "$ref": "#/$defs/ErrorFrame" },
        { "$ref": "#/$defs/PongFrame" }
      ]
    },

    "ClientFrame": {
      "description": "Any client-to-server LSDP/1 frame.",
      "oneOf": [
        { "$ref": "#/$defs/SubscribeFrame" },
        { "$ref": "#/$defs/InputFrame" },
        { "$ref": "#/$defs/PingFrame" },
        { "$ref": "#/$defs/UnsubscribeFrame" }
      ]
    }
  },

  "oneOf": [
    { "$ref": "#/$defs/ServerFrame" },
    { "$ref": "#/$defs/ClientFrame" }
  ]
}
